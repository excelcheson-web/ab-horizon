rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the request from an authenticated user? ─────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Helper: is the caller accessing their own document? ────────────────
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Helper: is the caller the authorised admin? ─────────────────────────
    // Checks the Firebase Auth token email — no Firestore profile field needed.
    // To change the admin email, update VITE_ADMIN_EMAIL in .env AND this rule.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'karladelbert83@gmail.com' ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // ── Profiles collection ─────────────────────────────────────────────────
    match /profiles/{userId} {
      // Any authenticated user can read any profile (admin panel needs this)
      allow read: if isAuthenticated();

      // Users can create only their own profile; admin can create any
      allow create: if isOwner(userId) || isAdmin();

      // Users can update their own profile; admin can update any profile
      allow update: if isOwner(userId) || isAdmin();

      // Hard deny all client-side deletes
      allow delete: if false;

      // ── Nested transactions subcollection ─────────────────────────────────
      match /transactions/{transactionId} {
        allow read:   if isAuthenticated();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }

      // Admin deletion markers prevent stale localStorage history from
      // re-uploading transactions that were intentionally removed.
      match /deletedTransactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isAdmin();
      }
    }

    // ── Users collection (legacy / additional data) ─────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    // ── Top-level transactions collection (legacy support) ──────────────────
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Admin collection ────────────────────────────────────────────────────
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // ── Default deny all ────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
